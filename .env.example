# OpenClaw Status — environment variables
# Copy to .env and fill in. .env is gitignored; never commit real keys.

# OpenRouter API key — required for the LLM assessment pipeline.
OPENROUTER_API_KEY=

# GitHub token — REQUIRED. All GitHub data (issues + releases) is read through the
# GitHub API with this token: one query returns reactions (👍), comment counts and
# body text, so the collector can rank issues by community impact and flag which
# ones affect the assessed version. Without it, issue/release collection fails.
#
# Least privilege — only public read is needed:
#   • Fine-grained PAT: Repository access = "Public repositories (read-only)",
#     Permissions → Issues: Read-only, Metadata: Read-only, Contents: Read-only.
#     (Contents is what gates the Releases API — omit it and release/changelog
#     fetches 403. The "Public repositories (read-only)" preset already covers it.)
#   • or a classic token with NO scopes (public read at 5,000 req/hr).
# Create at: GitHub → Settings → Developer settings → Personal access tokens.
GITHUB_TOKEN=

# Alert webhook — OPTIONAL. A Slack/Discord-style incoming webhook URL. When set,
# cost-threshold, budget-gate, and assessment-failure alerts are POSTed to it on top of
# stdout — the payload key is auto-selected from the URL: Discord webhooks get
# {"content": ...}, Slack and everything else {"text": ...}. Leave blank for stdout only.
ALERT_WEBHOOK_URL=
