# Secrets
.env

# Generated data artifacts + runtime state (raw-data/assessment/history/usage/
# run-log/etag-cache .json + the pipeline lock). All regenerated by the pipeline —
# kept out of source control so data churn doesn't pollute code diffs, and so no
# run output is ever committed. The code recreates data/ on first run.
data/

# Generated frontend output + rollback backups + per-version snapshots
web/index.html
web/*.html.prev
web/archive/

# Python
__pycache__/
*.pyc
.pytest_cache/

# Local Claude Code settings (and any other local Claude state)
.claude/
