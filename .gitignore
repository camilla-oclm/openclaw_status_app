web/feed.xml
web/badge.svg
web/llms.txt
web/llms-full.txt
web/robots.txt
web/sitemap.xml
web/*.html.prev
web/archive/

# Local design-prototype scratch dir (Phase 0 redesign — never committed)
web/proto/

# Python
__pycache__/
*.pyc
.pytest_cache/

# Local Claude Code settings (and any other local Claude state)
.claude/

