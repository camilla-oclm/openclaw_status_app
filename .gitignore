# Secrets
.env

# Generated data artifacts + runtime state (regenerated/accumulated by the
# pipeline — kept out of source control so data churn doesn't pollute code diffs).
data/raw-data.json
data/assessment.json
data/history.json
data/usage.json
data/run-log.json

# Generated frontend output + rollback backups
web/index.html
web/*.html.prev

# Python
__pycache__/
*.pyc
.pytest_cache/

# Local Claude Code settings
.claude/settings.local.json

# Lock files
data/.pipeline.lock
