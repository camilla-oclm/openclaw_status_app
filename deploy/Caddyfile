# Caddy serves the generated static page and gets/renews HTTPS automatically
# via Let's Encrypt. provision.sh substitutes __DOMAIN__ for the real domain
# and installs this at /etc/caddy/Caddyfile.
#
# Prereq: the domain's A-record must already point at this box (ports 80+443
# open) before Caddy can issue the certificate.
__DOMAIN__ {
	root * /opt/openclaw_status_app/web
	encode gzip
	# Every public page is a real file (index.html for "/", archive/<version>.html,
	# llms.txt, robots.txt, sitemap.xml, …), so serve them directly and let unknown
	# paths return a real 404. No SPA fallback — a blanket fallback to /index.html
	# turns every junk URL into a 200 soft-404 (duplicate content) that dilutes SEO.
	file_server
}
