# Pulls the latest code, then runs the adaptive scheduler *tick*: it decides whether a
# full collectâ†’assessâ†’render assessment is due and runs one only when warranted (a new
# release, or the cadence in config.ASSESS_CADENCE_TIERS). Most ticks are a cheap GitHub
# check with no LLM cost. Triggered hourly by openclaw-status.timer (not enabled alone).
[Unit]
Description=OpenClaw Status â€” pull latest code + run the scheduler tick
After=network-online.target
Wants=network-online.target
# Hard failure (git/collector crash, LLM timeout) â†’ ping the alert webhook. The deploy
# guard already keeps the last good page live; this is the only out-of-band signal it died.
OnFailure=openclaw-status-failure.service

[Service]
Type=oneshot
User=openclaw
Group=openclaw
WorkingDirectory=/opt/openclaw_status_app
Environment=PYTHONUNBUFFERED=1
# A failed pull (e.g. offline) must not block the scheduled run, hence the "-".
ExecStartPre=-/usr/bin/git -C /opt/openclaw_status_app pull --ff-only
ExecStart=/opt/openclaw_status_app/.venv/bin/python run.py tick
# Most ticks finish in seconds; when one decides to run, the full pipeline takes a few
# minutes. Must stay ABOVE config.COLLECT_TIMEOUT_S + PIPELINE_BUDGET_S + render margin
# (480 + 900 + ~60 â‰ˆ 1440) so the in-process budgets degrade gracefully â€” publishing the
# primary / keeping the last good page â€” before this SIGKILL can pre-empt them.
TimeoutStartSec=1800
Nice=10
